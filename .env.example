PORT=3000
NODE_ENV=production

# Zwitch uses https://api.zwitch.io for API calls.
# Select sandbox in the Zwitch dashboard and use sandbox keys for sandbox mode.
ZWITCH_ENV=sandbox
ZWITCH_BASE_URL=https://api.zwitch.io
ZWITCH_ACCESS_KEY=your_sandbox_access_key
ZWITCH_SECRET_KEY=your_sandbox_secret_key

# Default debit account / virtual account used as transfer wallet.
# You can override this per request with account_id or debit_account_id.
ZWITCH_ACCOUNT_ID=va_your_sandbox_transfer_wallet_account_id

# Optional. If set, /webhook/zwitch verifies x-zwitch-signature.
# Leave blank while testing webhook payloads manually from Postman.
ZWITCH_WEBHOOK_SECRET=
